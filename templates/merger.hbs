<div class="compendium-merger-form">

<p class="cm-hint">{{localize "COMPENDIUM-MERGER.App.ScopeHint"}}</p>
<p class="cm-hint">{{localize "COMPENDIUM-MERGER.App.PriorityHint"}}</p>

<label class="cm-filter-toggle">
  <input type="checkbox" name="filterEmptySources" {{#if filterEmptySources}}checked{{/if}} />
  {{localize "COMPENDIUM-MERGER.App.FilterEmptySources"}}
</label>

<nav class="cm-tabs">
  {{#each tabs as |tab|}}
    <a class="cm-tab-link {{#if tab.active}}active{{/if}}" data-tab="{{tab.id}}">
      {{localize tab.label}}
      {{#if tab.checkedCount}}<span class="cm-tab-count">{{tab.checkedCount}}</span>{{/if}}
    </a>
  {{/each}}
</nav>

<div class="cm-tab-panels">

<div class="cm-tab-panel {{#if items.active}}active{{/if}}" data-tab="items">
  {{#if items.hasSources}}
    <div class="cm-source-list">
      {{#each items.order as |entry|}}
        <div class="cm-source-row">
          <input type="checkbox" data-category="items" data-toggle-index="{{entry.index}}" {{#if entry.checked}}checked{{/if}} />
          <span class="cm-source-label">{{entry.label}}</span>
          <button type="button" class="cm-move" data-category="items" data-move-up="{{entry.index}}" title="{{localize 'COMPENDIUM-MERGER.App.MoveUp'}}"><i class="fa-solid fa-arrow-up"></i></button>
          <button type="button" class="cm-move" data-category="items" data-move-down="{{entry.index}}" title="{{localize 'COMPENDIUM-MERGER.App.MoveDown'}}"><i class="fa-solid fa-arrow-down"></i></button>
        </div>
      {{/each}}
    </div>
  {{else}}
    <p class="cm-hint">{{localize "COMPENDIUM-MERGER.App.NoItemSources"}}</p>
  {{/if}}
</div>

<div class="cm-tab-panel {{#if spells.active}}active{{/if}}" data-tab="spells">
  {{#if spells.hasSources}}
    <div class="cm-source-list">
      {{#each spells.order as |entry|}}
        <div class="cm-source-row">
          <input type="checkbox" data-category="spells" data-toggle-index="{{entry.index}}" {{#if entry.checked}}checked{{/if}} />
          <span class="cm-source-label">{{entry.label}}</span>
          <button type="button" class="cm-move" data-category="spells" data-move-up="{{entry.index}}" title="{{localize 'COMPENDIUM-MERGER.App.MoveUp'}}"><i class="fa-solid fa-arrow-up"></i></button>
          <button type="button" class="cm-move" data-category="spells" data-move-down="{{entry.index}}" title="{{localize 'COMPENDIUM-MERGER.App.MoveDown'}}"><i class="fa-solid fa-arrow-down"></i></button>
        </div>
      {{/each}}
    </div>
  {{else}}
    <p class="cm-hint">{{localize "COMPENDIUM-MERGER.App.NoItemSources"}}</p>
  {{/if}}
</div>

<div class="cm-tab-panel {{#if monsters.active}}active{{/if}}" data-tab="monsters">
  <div class="form-group">
    <label>{{localize "COMPENDIUM-MERGER.App.MonsterSortMode"}}</label>
    <select name="monsterSortMode">
      <option value="cr">{{localize "COMPENDIUM-MERGER.App.MonsterSortByCR"}}</option>
      <option value="type">{{localize "COMPENDIUM-MERGER.App.MonsterSortByType"}}</option>
    </select>
  </div>
  {{#if monsters.hasSources}}
    <div class="cm-source-list">
      {{#each monsters.order as |entry|}}
        <div class="cm-source-row">
          <input type="checkbox" data-category="monsters" data-toggle-index="{{entry.index}}" {{#if entry.checked}}checked{{/if}} />
          <span class="cm-source-label">{{entry.label}}</span>
          <button type="button" class="cm-move" data-category="monsters" data-move-up="{{entry.index}}" title="{{localize 'COMPENDIUM-MERGER.App.MoveUp'}}"><i class="fa-solid fa-arrow-up"></i></button>
          <button type="button" class="cm-move" data-category="monsters" data-move-down="{{entry.index}}" title="{{localize 'COMPENDIUM-MERGER.App.MoveDown'}}"><i class="fa-solid fa-arrow-down"></i></button>
        </div>
      {{/each}}
    </div>
  {{else}}
    <p class="cm-hint">{{localize "COMPENDIUM-MERGER.App.NoActorSources"}}</p>
  {{/if}}
</div>

<div class="cm-tab-panel {{#if vehicles.active}}active{{/if}}" data-tab="vehicles">
  {{#if vehicles.hasSources}}
    <div class="cm-source-list">
      {{#each vehicles.order as |entry|}}
        <div class="cm-source-row">
          <input type="checkbox" data-category="vehicles" data-toggle-index="{{entry.index}}" {{#if entry.checked}}checked{{/if}} />
          <span class="cm-source-label">{{entry.label}}</span>
          <button type="button" class="cm-move" data-category="vehicles" data-move-up="{{entry.index}}" title="{{localize 'COMPENDIUM-MERGER.App.MoveUp'}}"><i class="fa-solid fa-arrow-up"></i></button>
          <button type="button" class="cm-move" data-category="vehicles" data-move-down="{{entry.index}}" title="{{localize 'COMPENDIUM-MERGER.App.MoveDown'}}"><i class="fa-solid fa-arrow-down"></i></button>
        </div>
      {{/each}}
    </div>
  {{else}}
    <p class="cm-hint">{{localize "COMPENDIUM-MERGER.App.NoActorSources"}}</p>
  {{/if}}
</div>

<div class="cm-tab-panel {{#if species.active}}active{{/if}}" data-tab="species">
  {{#if species.hasSources}}
    <div class="cm-source-list">
      {{#each species.order as |entry|}}
        <div class="cm-source-row">
          <input type="checkbox" data-category="species" data-toggle-index="{{entry.index}}" {{#if entry.checked}}checked{{/if}} />
          <span class="cm-source-label">{{entry.label}}</span>
          <button type="button" class="cm-move" data-category="species" data-move-up="{{entry.index}}" title="{{localize 'COMPENDIUM-MERGER.App.MoveUp'}}"><i class="fa-solid fa-arrow-up"></i></button>
          <button type="button" class="cm-move" data-category="species" data-move-down="{{entry.index}}" title="{{localize 'COMPENDIUM-MERGER.App.MoveDown'}}"><i class="fa-solid fa-arrow-down"></i></button>
        </div>
      {{/each}}
    </div>
  {{else}}
    <p class="cm-hint">{{localize "COMPENDIUM-MERGER.App.NoItemSources"}}</p>
  {{/if}}
</div>

<div class="cm-tab-panel {{#if backgrounds.active}}active{{/if}}" data-tab="backgrounds">
  {{#if backgrounds.hasSources}}
    <div class="cm-source-list">
      {{#each backgrounds.order as |entry|}}
        <div class="cm-source-row">
          <input type="checkbox" data-category="backgrounds" data-toggle-index="{{entry.index}}" {{#if entry.checked}}checked{{/if}} />
          <span class="cm-source-label">{{entry.label}}</span>
          <button type="button" class="cm-move" data-category="backgrounds" data-move-up="{{entry.index}}" title="{{localize 'COMPENDIUM-MERGER.App.MoveUp'}}"><i class="fa-solid fa-arrow-up"></i></button>
          <button type="button" class="cm-move" data-category="backgrounds" data-move-down="{{entry.index}}" title="{{localize 'COMPENDIUM-MERGER.App.MoveDown'}}"><i class="fa-solid fa-arrow-down"></i></button>
        </div>
      {{/each}}
    </div>
  {{else}}
    <p class="cm-hint">{{localize "COMPENDIUM-MERGER.App.NoItemSources"}}</p>
  {{/if}}
</div>

<div class="cm-tab-panel {{#if classes.active}}active{{/if}}" data-tab="classes">
  {{#if classes.hasSources}}
    <div class="cm-source-list">
      {{#each classes.order as |entry|}}
        <div class="cm-source-row">
          <input type="checkbox" data-category="classes" data-toggle-index="{{entry.index}}" {{#if entry.checked}}checked{{/if}} />
          <span class="cm-source-label">{{entry.label}}</span>
          <button type="button" class="cm-move" data-category="classes" data-move-up="{{entry.index}}" title="{{localize 'COMPENDIUM-MERGER.App.MoveUp'}}"><i class="fa-solid fa-arrow-up"></i></button>
          <button type="button" class="cm-move" data-category="classes" data-move-down="{{entry.index}}" title="{{localize 'COMPENDIUM-MERGER.App.MoveDown'}}"><i class="fa-solid fa-arrow-down"></i></button>
        </div>
      {{/each}}
    </div>
  {{else}}
    <p class="cm-hint">{{localize "COMPENDIUM-MERGER.App.NoItemSources"}}</p>
  {{/if}}
</div>

<div class="cm-tab-panel {{#if feats.active}}active{{/if}}" data-tab="feats">
  {{#if feats.hasSources}}
    <div class="cm-source-list">
      {{#each feats.order as |entry|}}
        <div class="cm-source-row">
          <input type="checkbox" data-category="feats" data-toggle-index="{{entry.index}}" {{#if entry.checked}}checked{{/if}} />
          <span class="cm-source-label">{{entry.label}}</span>
          <button type="button" class="cm-move" data-category="feats" data-move-up="{{entry.index}}" title="{{localize 'COMPENDIUM-MERGER.App.MoveUp'}}"><i class="fa-solid fa-arrow-up"></i></button>
          <button type="button" class="cm-move" data-category="feats" data-move-down="{{entry.index}}" title="{{localize 'COMPENDIUM-MERGER.App.MoveDown'}}"><i class="fa-solid fa-arrow-down"></i></button>
        </div>
      {{/each}}
    </div>
  {{else}}
    <p class="cm-hint">{{localize "COMPENDIUM-MERGER.App.NoItemSources"}}</p>
  {{/if}}
</div>

</div>

<p class="cm-hint cm-warning">{{localize "COMPENDIUM-MERGER.App.RebuildWarning"}}</p>

{{#if result}}
<fieldset>
  <legend>{{localize "COMPENDIUM-MERGER.App.LastResultLegend"}}</legend>
  <p>{{localize "COMPENDIUM-MERGER.App.ResultPacksRead"}}: {{result.packsRead}}</p>
  <p>{{localize "COMPENDIUM-MERGER.App.ResultScanned"}}: {{result.scanned}}</p>
  <p>{{localize "COMPENDIUM-MERGER.App.ResultItems"}}: {{result.items}}</p>
  <p>{{localize "COMPENDIUM-MERGER.App.ResultSpells"}}: {{result.spells}}</p>
  <p>{{localize "COMPENDIUM-MERGER.App.ResultMonsters"}}: {{result.monsters}}</p>
  <p>{{localize "COMPENDIUM-MERGER.App.ResultVehicles"}}: {{result.vehicles}}</p>
  <p>{{localize "COMPENDIUM-MERGER.App.ResultSpecies"}}: {{result.species}}</p>
  <p>{{localize "COMPENDIUM-MERGER.App.ResultBackgrounds"}}: {{result.backgrounds}}</p>
  <p>{{localize "COMPENDIUM-MERGER.App.ResultClasses"}}: {{result.classes}}</p>
  <p>{{localize "COMPENDIUM-MERGER.App.ResultFeats"}}: {{result.feats}}</p>
  <p>{{localize "COMPENDIUM-MERGER.App.ResultSkipped"}}: {{result.skipped}}</p>
</fieldset>
{{/if}}

<footer class="sheet-footer">
  <button type="button" data-action="run-merge" {{#if running}}disabled{{/if}}>
    <i class="fa-solid fa-code-merge"></i>
    {{#if running}}
      {{localize "COMPENDIUM-MERGER.App.Running"}}
    {{else}}
      {{localize "COMPENDIUM-MERGER.App.RunMerge"}}
    {{/if}}
  </button>
</footer>

</div>
